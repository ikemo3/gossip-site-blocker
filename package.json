{
  "name": "gossip-site-blocker",
  "version": "1.17.1",
  "license": "MIT",
  "author": "Hideki Ikemoto",
  "type": "module",
  "scripts": {
    "archive": "tsx ./scripts/archive.ts",
    "build": "run-s build:*",
    "build:vite": "vite build",
    "build:manifest": "tsx ./scripts/make_manifest.ts",
    "dev": "vite",
    "fix": "ESLINT_USE_FLAT_CONFIG=true eslint --fix .",
    "format": "run-s format:*",
    "format:prettier": "prettier --write .",
    "format:sort-package-json": "sort-package-json",
    "lint": "run-s lint:*",
    "lint:dep": "depcruise .",
    "lint:eslint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
    "lint:prettier": "prettier --check .",
    "lint:sort-package-json": "sort-package-json --check",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "tabbyjs": "^12.0.3",
    "vanjs-core": "^1.6.0"
  },
  "devDependencies": {
    "@types/chrome": "0.2.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.3",
    "date-fns": "4.4.0",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-junit": "^9.0.1",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "sort-package-json": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "zip-a-folder": "6.1.2"
  },
  "packageManager": "pnpm@11.11.0"
}
